{
  "project": {
    "name": "LoadSense",
    "api_title": "LoadSense Backend",
    "default_route": "04L"
  },
  "server": {
    "host": "127.0.0.1",
    "port": 8000,
    "api_prefix": "/api"
  },
  "occupancy": {
    "default_capacity": 16,
    "overload_demo_buffer": 4,
    "thresholds": {
      "green_max": 0.5,
      "yellow_max": 0.75,
      "red_max": 1.0
    }
  },
  "route_monitoring": {
    "deviation_threshold_meters": 200.0
  },
  "artifacts": {
    "eta_model": "cloud/artifacts/eta_model.pkl",
    "demand_forecast_dir": "cloud/artifacts/demand"
  },
  "data": {
    "country_database_dir": "data/countries",
    "synthetic_history": "data/synthetic_occupancy_logs.csv",
    "edge_counter_output": "data/edge_line_crossing_counts.csv",
    "synthetic_rows": 500
  },
  "safety": {
    "speed_limit_kph": 60,
    "sudden_stop_delta_kph": 25
  },
  "mock_telemetry": {
    "vehicle_id": "J-001",
    "start_occupancy": 0,
    "max_occupancy": 16,
    "interval_seconds": 1.0,
    "stdout_limit": 0
  },
  "edge_counter": {
    "frames": 240,
    "line_y": 240
  },
  "eta_fallback": {
    "base_minutes": 5.0,
    "stop_weight": 0.75,
    "traffic_weight": 1.5,
    "time_of_day_weight": 0.05
  }
}
